<html><head><HTA:APPLICATION WINDOWSTATE="normal" SHOWINTASKBAR="no" BORDER="none" CAPTION="no" SCROLL="no"><title>CSV Downloader</title><script language="VBScript">
Sub Window_OnLoad
window.resizeTo 10,10 : window.moveTo (screen.availWidth - 10) \ 2, (screen.availHeight - 10) \ 2
 Set fso = CreateObject("Scripting.FileSystemObject") : Set results = fso.OpenTextFile("Results.txt", 8, True)
 If Not fso.FileExists("disposition.txt") Then
  MsgBox "disposition.txt not found" : window.close
 End If
 Set f = fso.OpenTextFile("disposition.txt", 1)
 Do Until f.AtEndOfStream
  line = Trim(f.ReadLine)
  If line <> "" Then
   parts = Split(line, ",")
   If UBound(parts) = 1 Then
    filename = Trim(parts(0)) : url = Trim(parts(1)) : Call DownloadOne(url, filename, results)
   Else
    results.WriteLine Now & " BAD LINE: " & line
   End If
  End If
 Loop
 f.Close : results.Close
' To NOT show the "Done" message add ' to start of next line same as this line
MsgBox "Done. See Results.txt." : window.close
End Sub

Sub DownloadOne(url, filename, results)
 On Error Resume Next
 url = Replace(url, " ", "%20")
 Set xhr = CreateObject("MSXML2.XMLHTTP") : xhr.open "GET", url, False : xhr.send
 If xhr.status = 200 Then
  Set s = CreateObject("ADODB.Stream") : s.Type = 1 : s.Open : s.Write xhr.responseBody : s.SaveToFile filename, 2 : s.Close
  results.WriteLine Now & " OK: " & filename & " <- " & url
 Else
  results.WriteLine Now & " ERR " & xhr.status & ": " & url
 End If
End Sub
</script></head><body></body></html>